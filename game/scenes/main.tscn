[node name="Body" type="Label" parent="Overlays/LetterOverlay/Panel/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_colors/font_color = Color(0.22, 0.14, 0.06, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 0)
theme_override_constants/outline_size = 0
theme_override_font_sizes/font_size = 18
text = "Klucz skrzypi głośniej niż pamiętam.

Drzwi puszczają z trudem. W twarz bucha mi stęchłe, zimne powietrze — jakby nikt tu nie oddychał od tygodni.

Coś chrzęści pod butem.

Czuję ten zapach — suchej ziemi i czegoś gorszego. Moje rośliny zwiędły z tęsknoty.

Muszę uratować te, które jeszcze żyją.

...co to za dźwięk z salonu?"
autowrap_mode = 3

[node name="ContinueBtn" type="Button" parent="Overlays/LetterOverlay/Panel/VBox"]
custom_minimum_size = Vector2(260, 54)
layout_mode = 2
size_flags_horizontal = 4
text = "Kontynuuj"

